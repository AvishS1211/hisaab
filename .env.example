# Copy this file to .env.local and fill in your Supabase project's values.
# Both are safe to expose in the browser (the anon key is protected by RLS).
# Never put the service_role / secret key here — it must stay server-only.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
